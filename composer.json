{
    "name": "neptune/r606_eval",
    "description": "Evaluation R606",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Neptune\\R606Eval\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Neptune2k21",
            "email": "mamadou_cisse01@etu.ube.fr"
        }
    ],
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.94"
    },
    "scripts": {
        "phpstan": "phpstan analyse --configuration=phpstan.neon",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "quality": [
            "@cs-check",
            "@phpstan"
        ]
    }
}
